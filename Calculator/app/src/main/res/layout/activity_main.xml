<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- RESULT DISPLAY -->
    <TextView
        android:id="@+id/result"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:gravity="end|bottom"
        android:padding="16dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="24sp"
        android:autoSizeMaxTextSize="64sp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonGrid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.3"/>

    <!-- BUTTON GRID -->
    <GridLayout
        android:id="@+id/buttonGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:columnCount="4"
        android:rowCount="5"
        android:padding="8dp"
        android:useDefaultMargins="true"

        app:layout_constraintTop_toBottomOf="@id/result"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button style="@style/CalcButtonRed" android:text="C" android:onClick="clearClick"/>
        <Button style="@style/CalcButton" android:text="0" android:onClick="numberClick"/>
        <Button style="@style/CalcButtonGreen" android:text="=" android:onClick="equalClick"/>
        <Button style="@style/CalcButtonOperator" android:text="+" android:onClick="operatorClick"/>

        <Button style="@style/CalcButton" android:text="1" android:onClick="numberClick"/>
        <Button style="@style/CalcButton" android:text="2" android:onClick="numberClick"/>
        <Button style="@style/CalcButton" android:text="3" android:onClick="numberClick"/>
        <Button style="@style/CalcButtonOperator" android:text="-" android:onClick="operatorClick"/>

        <Button style="@style/CalcButton" android:text="4" android:onClick="numberClick"/>
        <Button style="@style/CalcButton" android:text="5" android:onClick="numberClick"/>
        <Button style="@style/CalcButton" android:text="6" android:onClick="numberClick"/>
        <Button style="@style/CalcButtonOperator" android:text="*" android:onClick="operatorClick"/>

        <Button style="@style/CalcButton" android:text="7" android:onClick="numberClick"/>
        <Button style="@style/CalcButton" android:text="8" android:onClick="numberClick"/>
        <Button style="@style/CalcButton" android:text="9" android:onClick="numberClick"/>
        <Button style="@style/CalcButtonOperator" android:text="/" android:onClick="operatorClick"/>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>